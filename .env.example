# ─── Clstr CA Portal — Environment Variables Template ────────────────────────
# Copy this file to .env (and .env.production for prod) and fill in real values.
# NEVER commit .env to git — it is already in .gitignore.

# ─── Primary Supabase Project (CA Portal own data) ───────────────────────────
# Anon/public key ONLY — never the service_role key in frontend code
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Secondary Supabase Project (Main Clstr app — for live verified user count)
# Leave blank to use fallback count. Anon key only.
VITE_SECONDARY_SUPABASE_URL=
VITE_SECONDARY_SUPABASE_ANON_KEY=

# ─── Sentry (Error Monitoring) ────────────────────────────────────────────────
# Get DSN from sentry.io → your project → Settings → Client Keys
VITE_SENTRY_DSN=

# ─── App Environment ─────────────────────────────────────────────────────────
VITE_APP_ENV=development
